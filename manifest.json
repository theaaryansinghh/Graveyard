{
  "manifest_version": 3,
  "name": "Graveyard",
  "version": "1.0.0",
  "description": "Scans your inbox and tracks job application replies so you can face the rejections all at once, not one by one.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "downloads"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup2.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_background_color": "#1a1a1a"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}